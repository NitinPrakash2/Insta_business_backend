{
  "info": {
    "name": "Instagram Commerce API",
    "description": "Complete API flow for Instagram Business Account connection and product catalog sync",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "OAuth Flow",
      "item": [
        {
          "name": "1. Start OAuth",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"seller_123\",\n  \"redirect_uri\": \"http://localhost:5173/oauth/callback\"\n}"
            },
            "url": {
              "raw": "http://localhost:8000/client/api/i/ona/instagram?typ=meta_oauth_start",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["client", "api", "i", "ona", "instagram"],
              "query": [
                {
                  "key": "typ",
                  "value": "meta_oauth_start"
                }
              ]
            },
            "description": "Get OAuth authorization URL from Meta"
          }
        },
        {
          "name": "2. OAuth Callback (After Manual Login)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"seller_123\",\n  \"code\": \"YOUR_AUTH_CODE_FROM_CALLBACK\",\n  \"redirect_uri\": \"http://localhost:5173/oauth/callback\"\n}"
            },
            "url": {
              "raw": "http://localhost:8000/client/api/i/ona/instagram?typ=meta_oauth_callback",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["client", "api", "i", "ona", "instagram"],
              "query": [
                {
                  "key": "typ",
                  "value": "meta_oauth_callback"
                }
              ]
            },
            "description": "Exchange authorization code for access token. Copy 'code' from OAuth callback URL."
          }
        },
        {
          "name": "3. Check Connection Status",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"seller_123\"\n}"
            },
            "url": {
              "raw": "http://localhost:8000/client/api/i/ona/instagram?typ=meta_connection_status",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["client", "api", "i", "ona", "instagram"],
              "query": [
                {
                  "key": "typ",
                  "value": "meta_connection_status"
                }
              ]
            },
            "description": "Verify Instagram connection and get token expiry info"
          }
        }
      ]
    },
